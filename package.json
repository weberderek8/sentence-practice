{
  "name": "sentence-practice",
  "version": "0.1.0",
  "private": true,
  "description": "Personal app for practicing sentences: store an English sentence, its translation, and an audio recording.",
  "workspaces": [
    "packages/*",
    "services/*",
    "web"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "dev:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build",
    "prod:down": "docker compose -f docker-compose.yml -f docker-compose.prod.yml down",
    "prod:logs": "docker compose -f docker-compose.yml -f docker-compose.prod.yml logs -f"
  },
  "engines": {
    "node": ">=20"
  }
}

# ----------------------------------------------------------------------------
# Sentence Practice — environment configuration
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored and
# must NEVER be committed. On the home server, create `.env` after `git pull`.
# ----------------------------------------------------------------------------

# --- MongoDB ---------------------------------------------------------------
# Root credentials for the mongo container. Change these on the home server.
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=changeme

# Database names owned by each service (single mongo instance, separate DBs).
SENTENCES_DB_NAME=sentences_db
AUDIO_DB_NAME=audio_db

# Connection strings used by the services. `mongo` is the compose service name
# resolved on the internal Docker network. authSource=admin because the user is
# created in the admin DB by MONGO_INITDB_ROOT_*.
SENTENCES_MONGO_URI=mongodb://root:changeme@mongo:27017/sentences_db?authSource=admin
AUDIO_MONGO_URI=mongodb://root:changeme@mongo:27017/audio_db?authSource=admin

# --- Service ports (container-internal) ------------------------------------
GATEWAY_PORT=8080
SENTENCES_PORT=4001
AUDIO_PORT=4002

# --- Internal service URLs (used by the gateway to proxy) ------------------
SENTENCES_URL=http://sentences:4001
AUDIO_URL=http://audio:4002
GATEWAY_URL=http://gateway:8080

# --- Web entry -------------------------------------------------------------
# The single port exposed on the host (home LAN reaches the app here in prod).
WEB_PORT=8000

# --- Dev-only debug ports (mapped to host by docker-compose.dev.yml) -------
GATEWAY_DEBUG_PORT=8080
SENTENCES_DEBUG_PORT=4001
AUDIO_DEBUG_PORT=4002
MONGO_DEBUG_PORT=27017
VITE_DEV_PORT=5173

# Max audio upload size in bytes (default 25MB).
MAX_AUDIO_BYTES=26214400
